baseURL = "https://lanpinktattoo.com/"
languageCode = "vi-vn"
title = "Lan Pink Tattoo"
defaultContentLanguage = "vi"
defaultContentLanguageInSubdir = false
hasCJKLanguage = false
enableRobotsTXT = true

[languages]
  [languages.vi]
    languageName = "Tiếng Việt"
    weight = 1
    title = "Lan Pink Tattoo"
    contentDir = "content/vi"

    [languages.vi.params]
      description = "Studio xăm nghệ thuật tại TP.HCM - Chuyên Fine Line, Mini Tattoo, Blackwork và thiết kế hình xăm độc bản"
      flag = "🇻🇳"

    [[languages.vi.menu.main]]
      name = "Tác phẩm"
      pageRef = "/tac-pham"
      weight = 1

    [[languages.vi.menu.main]]
      name = "Ý nghĩa hình xăm"
      pageRef = "/y-nghia-hinh-xam"
      weight = 2

    [[languages.vi.menu.main]]
      name = "Mẫu hình xăm đẹp"
      pageRef = "/mau-hinh-xam-dep"
      weight = 3

    [[languages.vi.menu.main]]
      name = "Phong cách xăm"
      pageRef = "/phong-cach-xam"
      weight = 4

    [[languages.vi.menu.main]]
      name = "Cẩm nang"
      pageRef = "/cam-nang-tattoo"
      weight = 5

    [[languages.vi.menu.main]]
      name = "Bảng giá"
      pageRef = "/bang-gia"
      weight = 6

    [[languages.vi.menu.main]]
      name = "Thành viên"
      pageRef = "/quy-tac-tich-diem"
      weight = 7



  [languages.en]
    languageName = "English"
    weight = 2
    title = "Lan Pink Tattoo"
    contentDir = "content/en"

    [languages.en.params]
      description = "Private tattoo studio in Ho Chi Minh City - Fine Line, Mini Tattoo, Blackwork and custom tattoo design"
      flag = "🇺🇸"

    [[languages.en.menu.main]]
      name = "Portfolio"
      pageRef = "/portfolio"
      weight = 1

    [[languages.en.menu.main]]
      name = "Tattoo Meanings"
      pageRef = "/tattoo-meanings"
      weight = 2

    [[languages.en.menu.main]]
      name = "Tattoo Ideas"
      pageRef = "/tattoo-designs"
      weight = 3

    [[languages.en.menu.main]]
      name = "Tattoo Styles"
      pageRef = "/tattoo-styles"
      weight = 4

    [[languages.en.menu.main]]
      name = "Guide"
      pageRef = "/tattoo-guide"
      weight = 5

    [[languages.en.menu.main]]
      name = "Pricing"
      pageRef = "/pricing"
      weight = 6

    [[languages.en.menu.main]]
      name = "Rewards"
      pageRef = "/lan-pink-member"
      weight = 7


[markup]
  [markup.goldmark]
    [markup.goldmark.renderer]
      unsafe = true

  [markup.highlight]
    noClasses = false
    style = "monokai"

[params]
  author = "Lan Pink"
  studio = "Lan Pink Tattoo"
  city = "Ho Chi Minh City"
  email = "hello@lanpinktattoo.com"
  phone = "+84 703 659 902"
  instagram = "https://www.instagram.com/lanpink.ink/"
  facebook = "https://www.facebook.com/LanPinkInk"
  messenger = "https://m.me/LanPinkInk"
  googleBusiness = "https://maps.app.goo.gl/FWkCMzaZBN5G6rZJ9"
  bookingUrl = "https://m.me/LanPinkInk"
  memberProgramUrl = "/quy-tac-tich-diem/"
  memberAppUrl = "lanpinkmember://open"

[outputs]
  home = ["HTML", "RSS"]

[sitemap]
  changefreq = "weekly"
  priority = 0.5
  filename = "sitemap.xml"

[related]
  threshold = 50
  includeNewer = true
  toLower = true

  [[related.indices]]
    name = "tags"
    weight = 100

  [[related.indices]]
    name = "title"
    weight = 70

  [[related.indices]]
    name = "description"
    weight = 50


[[menus.footer]]
name = "Chương trình khuyến mãi"
url = "/khuyen-mai/"
weight = 30
