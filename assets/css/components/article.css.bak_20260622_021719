/* ===== LAN PINK MEMBER RULES ===== */

.page-content table,
.post-content table,
.article-content table {
    width: auto;
    min-width: 620px;
    max-width: 720px;
    margin: 24px auto;
}

.page-content table th,
.page-content table td,
.post-content table th,
.post-content table td,
.article-content table th,
.article-content table td {
    padding: 12px 18px;
}

.member-lookup-cta{
    display:flex;
    justify-content:center;
    margin:24px 0;
}

.member-lookup-cta a{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:14px 24px;
    border-radius:999px;
    border:1px solid var(--color-primary);
    font-size:1.15rem;
    font-weight:700;
    text-decoration:none;
    transition:all .25s ease;
}

.member-lookup-cta a:hover{
    transform:translateY(-2px);
}