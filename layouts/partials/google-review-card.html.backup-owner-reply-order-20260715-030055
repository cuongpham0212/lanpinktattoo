{{- $reviewID := .Params.google_review_id -}}
{{- $lang := .Site.Language.Lang -}}
{{- $isEN := eq $lang "en" -}}

{{- if $reviewID -}}
  {{- $data := site.Data.google_reviews -}}

  {{- /* Tương thích cả schema cũ và schema v1. */ -}}
  {{- $reviews := $data -}}
  {{- with $data.reviews -}}
    {{- $reviews = . -}}
  {{- end -}}

  {{- $review := index $reviews $reviewID -}}

  {{- if $review -}}
    {{- $translationStatus := $review.translation_status | default "" -}}
    {{- $originalLanguage := $review.original_language | default "" -}}
    {{- $originalText := $review.review_text_original | default $review.review_text | default "" -}}
    {{- $textVI := $review.review_text_vi | default "" -}}
    {{- $textEN := $review.review_text_en | default "" -}}

    {{- /*
      Schema mới: chọn thẳng trường theo ngôn ngữ trang.
      Fallback chỉ dành cho record cũ chưa được duyệt lại.
    */ -}}
    {{- $displayText := $originalText -}}

    {{- if $isEN -}}
      {{- if $textEN -}}
        {{- $displayText = $textEN -}}
      {{- end -}}
    {{- else -}}
      {{- if $textVI -}}
        {{- $displayText = $textVI -}}
      {{- end -}}
    {{- end -}}

    {{- /* Nhãn minh bạch: nội dung gốc hay bản dịch. */ -}}
    {{- $languageLabel := "" -}}

    {{- if eq $originalLanguage "vi" -}}
      {{- if $isEN -}}
        {{- if $textEN -}}
          {{- $languageLabel = "Translated from the original Vietnamese review" -}}
        {{- else -}}
          {{- $languageLabel = "Original review in Vietnamese" -}}
        {{- end -}}
      {{- else -}}
        {{- $languageLabel = "Đánh giá gốc bằng tiếng Việt" -}}
      {{- end -}}

    {{- else if eq $originalLanguage "en" -}}
      {{- if $isEN -}}
        {{- $languageLabel = "Original review in English" -}}
      {{- else -}}
        {{- if $textVI -}}
          {{- $languageLabel = "Bản dịch tiếng Việt từ đánh giá gốc tiếng Anh" -}}
        {{- else -}}
          {{- $languageLabel = "Đánh giá gốc bằng tiếng Anh" -}}
        {{- end -}}
      {{- end -}}

    {{- else if eq $translationStatus "original_vi" -}}
      {{- if $isEN -}}
        {{- $languageLabel = "Original review in Vietnamese" -}}
      {{- else -}}
        {{- $languageLabel = "Đánh giá gốc bằng tiếng Việt" -}}
      {{- end -}}

    {{- else if eq $translationStatus "translated" -}}
      {{- if $isEN -}}
        {{- $languageLabel = "Original review in English" -}}
      {{- else -}}
        {{- $languageLabel = "Bản dịch tiếng Việt từ đánh giá gốc tiếng Anh" -}}
      {{- end -}}

    {{- else -}}
      {{- if $isEN -}}
        {{- $languageLabel = "Verified Google review" -}}
      {{- else -}}
        {{- $languageLabel = "Đánh giá đã xác thực từ Google" -}}
      {{- end -}}
    {{- end -}}

    {{- $dateFormat := cond $isEN "Jan 2, 2006" "02/01/2006" -}}

<section class="lp-google-review-card">
  <div class="lp-google-review-intro">
    <div>
      <h2>
        {{- if $isEN -}}
          What do clients say about Lan Pink?
        {{- else -}}
          Khách hàng nói gì về Lan Pink?
        {{- end -}}
      </h2>

      <div
        class="lp-google-review-stars"
        aria-label="{{ default 5 $review.rating }} out of 5 stars"
      >
        {{- range seq 1 (int (default 5 $review.rating)) -}}
          <span aria-hidden="true">★</span>
        {{- end -}}
      </div>

      <strong>{{ $review.reviewer_name }}</strong>

      <p class="lp-google-review-meta">
        <span class="lp-google-review-language">
          {{ $languageLabel }}
        </span>

        {{- with $review.review_date }}
          <span aria-hidden="true"> · </span>

          <time
            datetime="{{ . }}"
            {{- with $review.review_date_relative }}
              title="{{ if $isEN }}Google displayed: {{ . }}{{ else }}Google hiển thị: {{ . }}{{ end }}"
            {{- end }}
          >
            {{- time.Format $dateFormat . -}}
          </time>
        {{- end }}
      </p>
    </div>

    {{- with $review.google_review_url }}
    <a
      class="lp-google-review-verified"
      href="{{ . }}"
      target="_blank"
      rel="nofollow noopener"
    >
      {{- if $isEN -}}
        Verified on Google Review →
      {{- else -}}
        Đã xác thực từ Google Review →
      {{- end -}}
    </a>
    {{- end }}
  </div>

  {{- with $displayText }}
  <p class="lp-google-review-text">“{{ . }}”</p>
  {{- end }}

  {{- $ownerReplyOriginal := $review.owner_reply_original | default $review.owner_reply | default "" -}}
  {{- $ownerReplyVI := $review.owner_reply_vi | default "" -}}
  {{- $ownerReplyEN := $review.owner_reply_en | default "" -}}
  {{- $ownerReplyDisplay := $ownerReplyOriginal -}}

  {{- if $isEN -}}
    {{- if $ownerReplyEN -}}
      {{- $ownerReplyDisplay = $ownerReplyEN -}}
    {{- end -}}
  {{- else -}}
    {{- if $ownerReplyVI -}}
      {{- $ownerReplyDisplay = $ownerReplyVI -}}
    {{- end -}}
  {{- end -}}

  {{- with $ownerReplyDisplay }}
  <div class="lp-google-review-owner-reply">
    <strong>
      {{- if $isEN -}}
        Response from Lan Pink Ink
      {{- else -}}
        Phản hồi từ Lan Pink Ink
      {{- end -}}
    </strong>

    <p>{{ . }}</p>
  </div>
  {{- end }}

  {{- $reviewAttributes := $review.review_attributes | default (slice) -}}

  {{- if gt (len $reviewAttributes) 0 -}}
    <div class="lp-google-review-details">
      {{- range $attribute := $reviewAttributes -}}
        {{- if $attribute.displayable -}}
          {{- $label := $attribute.label_vi | default $attribute.label_original | default $attribute.key -}}
          {{- $question := $attribute.question_vi | default $attribute.question_original -}}
          {{- $value := $attribute.value_vi | default $attribute.value_original -}}

          {{- if $isEN -}}
            {{- $label = $attribute.label_en | default $attribute.label_original | default $attribute.key -}}
            {{- $question = $attribute.question_en -}}
            {{- $value = $attribute.value_original | default $attribute.value_vi -}}
          {{- end -}}

          {{- with $value -}}
          <div class="lp-google-review-detail-item">
            <strong>{{ $label }}</strong>
            {{- with $question }}
            <div class="lp-google-review-detail-question">{{ . }}</div>
            {{- end }}
            <div class="lp-google-review-detail-answer">{{ . }}</div>
          </div>
          {{- end -}}
        {{- end -}}
      {{- end -}}
    </div>
  {{- else -}}
    {{- /* Fallback cho review cũ chưa có review_attributes. */ -}}
    <div class="lp-google-review-details">
      {{- with $review.service_price }}<div class="lp-google-review-detail-item"><strong>{{ if $isEN }}Price{{ else }}Giá{{ end }}:</strong><br><span>{{ . }}</span></div>{{- end }}
      {{- with $review.service_note }}<div class="lp-google-review-detail-item"><strong>{{ if $isEN }}Service{{ else }}Dịch vụ{{ end }}:</strong><br><span>{{ . }}</span></div>{{- end }}
      {{- with $review.style_request }}<div class="lp-google-review-detail-item"><strong>{{ if $isEN }}Requested style{{ else }}Phong cách đã yêu cầu{{ end }}:</strong><br><span>{{ . }}</span></div>{{- end }}
      {{- with $review.cleanliness }}<div class="lp-google-review-detail-item"><strong>{{ if $isEN }}Cleanliness{{ else }}Mức độ sạch sẽ{{ end }}:</strong><br><span>{{ . }}</span></div>{{- end }}
      {{- with $review.artist_feedback }}<div class="lp-google-review-detail-item"><strong>{{ if $isEN }}Artist feedback{{ else }}Nhà tạo mẫu{{ end }}:</strong><br><span>{{ . }}</span></div>{{- end }}
    </div>
  {{- end -}}

{{- $gallerySlug := $review.feedback_gallery_slug | default "" -}}
  {{- $gallery := index site.Data.galleries $gallerySlug -}}

  {{- if and $gallery $gallery.images }}
    <div class="lp-google-review-images">
      {{- range $gallery.images }}
        {{- $src := or .src .url .image .cdn -}}

        {{- if $src }}
        <a
          href="{{ $src }}"
          target="_blank"
          rel="nofollow noopener"
        >
          <img
            src="{{ $src }}"
            alt="{{ or .alt (cond $isEN "Client feedback photo at Lan Pink Tattoo" "Ảnh feedback khách hàng tại Lan Pink Tattoo") }}"
            loading="lazy"
          >
        </a>
        {{- end }}
      {{- end }}
    </div>

  {{- else }}
    {{- with $review.feedback_images }}
    <div class="lp-google-review-images">
      {{- range . }}
      <a
        href="{{ . }}"
        target="_blank"
        rel="nofollow noopener"
      >
        <img
          src="{{ . }}"
          alt="{{ if $isEN }}Client feedback photo at Lan Pink Tattoo{{ else }}Ảnh feedback khách hàng tại Lan Pink Tattoo{{ end }}"
          loading="lazy"
        >
      </a>
      {{- end }}
    </div>
    {{- end }}
  {{- end }}

  <div class="lp-google-review-foot">
    {{- if $isEN -}}
      Real client review after a tattoo session at Lan Pink Ink Studio
    {{- else -}}
      Review thật từ khách hàng sau buổi xăm tại Lan Pink Ink Studio
    {{- end -}}
  </div>
</section>

  {{- end -}}
{{- end -}}
