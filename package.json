{
  "name": "albumgaixinh",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "hugo --gc --minify",
    "dev": "npm run watch:css & hugo server -D",
    "build:css": "npx tailwindcss -i ./assets/css/input.css -o ./static/css/style.css --minify",
    "watch:css": "npx tailwindcss -i ./assets/css/input.css -o ./static/css/style.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.15",
    "postcss": "^8.4.31",
    "postcss-cli": "^10.1.0",
    "tailwindcss": "^3.4.1"
  }
}
